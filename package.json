    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wxt": "^0.20.0"
  }
}
